# Web 服务端口（docker compose up 时使用）
WEB_PORT=8080

# FMP 金融数据 API（留空则使用占位数据）
FMP_API_KEY=

# LLM 解卦 API（留空则使用本地规则兜底）
LLM_API_KEY=
LLM_PROVIDER=openai

# 可选：覆盖起卦日期，便于本地复现（格式 YYYY-MM-DD）
# ORACLE_DATE=2026-06-05

# 可选：自定义路径（一般无需修改）
# OUTPUT_PATH=/app/public/daily_result.json
# TICKERS_FILE=/app/backend/tickers.txt
